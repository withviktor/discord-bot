{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "Discord bot with NestJS-like architecture",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:sharded": "tsx src/shard.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "start:sharded": "node dist/shard.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "db:start": "bash scripts/db.sh",
    "db:stop": "docker compose stop postgres",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.0.0",
    "@t3-oss/env-core": "^0.12.0",
    "discord.js": "^14.17.0",
    "dotenv": "^16.4.5",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.22.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "@prisma/engines", "esbuild", "prisma"]
  }
}

DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/discord_bot

# Sharding (optional) — only used when running start:sharded / dev:sharded.
# Set to a positive integer to pin the shard count, or omit to let Discord decide ("auto").
# TOTAL_SHARDS=auto
